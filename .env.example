# GitHub Personal Access Token (scopes: repo, workflow)
GITHUB_PAT=your_github_pat_here

# JDK 8 runtime base image (Layer 1) — override per environment
JDK_BASE_IMAGE=eclipse-temurin:8-jre

# Path to opspulse.yaml (default: project root)
OPS_PULSE_CONFIG=./opspulse.yaml

# Optional: Harness API key (enterprise CI/CD)
# HARNESS_API_KEY=
