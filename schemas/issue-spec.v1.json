{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opspulse.dev/schemas/issue-spec.v1.json",
  "title": "OpsPulse Issue Spec v1",
  "description": "YAML frontmatter contract for GitHub Issues driving Issue-to-Deploy workflows.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "opspulse_version",
    "type",
    "service",
    "runtime",
    "build",
    "deploy",
    "acceptance"
  ],
  "properties": {
    "opspulse_version": {
      "type": "string",
      "const": "1",
      "description": "Issue Spec schema version."
    },
    "type": {
      "type": "string",
      "enum": ["feature", "bugfix", "chore", "infra"],
      "description": "Issue delivery type."
    },
    "scope": {
      "type": "string",
      "enum": ["api", "config", "deploy", "infra", "docs"],
      "description": "Change scope within the service."
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Microservice name (e.g. order-service)."
        },
        "module_path": {
          "type": "string",
          "minLength": 1,
          "description": "Path to the service module in the user repository."
        }
      }
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"],
      "description": "Delivery priority."
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["jdk_base_image"],
      "properties": {
        "jdk_base_image": {
          "type": "string",
          "minLength": 1,
          "description": "Layer 1 JDK 8 runtime base image reference."
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "artifact"],
      "properties": {
        "tool": {
          "type": "string",
          "enum": ["maven", "gradle"],
          "description": "Build tool for the microservice."
        },
        "jdk": {
          "type": "string",
          "pattern": "^1\\.8$",
          "description": "JDK version for the build (must be 1.8)."
        },
        "command": {
          "type": "string",
          "minLength": 1,
          "description": "Shell command to build the microservice artifact."
        },
        "artifact": {
          "type": "string",
          "minLength": 1,
          "description": "Path to the built jar/war relative to repo root."
        }
      }
    },
    "deploy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["env"],
      "properties": {
        "dockerfile": {
          "type": "string",
          "minLength": 1,
          "description": "Dockerfile path (FROM jdk_base_image + COPY artifact)."
        },
        "image": {
          "type": "string",
          "minLength": 1,
          "description": "Target registry image for the service (Layer 3)."
        },
        "tag_strategy": {
          "type": "string",
          "minLength": 1,
          "description": "Image tag pattern, e.g. issue-{issue_number}-{git_short_sha}."
        },
        "env": {
          "type": "string",
          "enum": ["dev", "staging", "prod"],
          "description": "Target deployment environment."
        }
      }
    },
    "harness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pipeline": {
          "type": "string",
          "enum": ["pr-validation", "deploy-dev", "deploy-staging", "deploy-prod"],
          "description": "Default Harness pipeline identifier."
        },
        "vars": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Pipeline variables passed to Harness or local-runner."
        }
      }
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "given", "then"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-[0-9]+$",
            "description": "Acceptance criterion identifier."
          },
          "given": {
            "type": "string",
            "minLength": 1,
            "description": "Precondition for the acceptance test."
          },
          "then": {
            "type": "string",
            "minLength": 1,
            "description": "Expected outcome when acceptance passes."
          }
        }
      },
      "description": "At least one acceptance criterion is required."
    },
    "affected_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Glob paths the agent may modify; recommended for feature/bugfix."
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "name"],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1,
          "description": "GitHub repository owner (user or org)."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "GitHub repository name."
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "description": "Git branch or tag for workflow_dispatch (default: main)."
        }
      },
      "description": "Target business repository for CI and status comments."
    },
    "ci": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workflow": {
          "type": "string",
          "minLength": 1,
          "description": "Workflow file name, e.g. cicd.yml"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "workflow_dispatch inputs passed to GitHub Actions."
        }
      },
      "description": "Per-issue CI override; merges with opspulse.yaml repository defaults."
    }
  }
}
